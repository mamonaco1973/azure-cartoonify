<mxfile host="app.diagrams.net" agent="Claude">
  <diagram id="cartoonify-flow" name="How to Cartoonify an Image">
    <mxGraphModel grid="1" page="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="950" pageHeight="1800" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" value="Cartoonify Workflow" vertex="1">
          <mxGeometry height="44" width="750" x="75" y="20" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="130" width="750" x="75" y="82" as="geometry" />
        </mxCell>
        <mxCell id="s1n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="①" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="97" as="geometry" />
        </mxCell>
        <mxCell id="s1t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Sign In with Entra External ID&lt;/b&gt;&lt;br&gt;Open the app in the browser (Blob Storage static URL) and click &lt;b&gt;Sign In&lt;/b&gt;. The browser redirects to the &lt;b&gt;Entra External ID sign-in page&lt;/b&gt;.&lt;br&gt;Enter your email and password — or sign up for a new account. Entra validates credentials and redirects&lt;br&gt;to &lt;b&gt;callback.html&lt;/b&gt; with an authorization code. The PKCE exchange returns access, ID, and refresh&lt;br&gt;tokens stored in &lt;b&gt;sessionStorage&lt;/b&gt;. The UI unlocks and the history gallery loads." vertex="1">
          <mxGeometry height="115" width="657" x="158" y="92" as="geometry" />
        </mxCell>
        <mxCell id="a12" edge="1" parent="1" source="s1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="120" width="750" x="75" y="242" as="geometry" />
        </mxCell>
        <mxCell id="s2n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="②" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="257" as="geometry" />
        </mxCell>
        <mxCell id="s2t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Select &amp;amp; Validate Image&lt;/b&gt;&lt;br&gt;Use the file picker to select a photo. The browser validates immediately — no server round-trip required.&lt;br&gt;File type must be &lt;b&gt;JPEG, PNG, or WebP&lt;/b&gt;; file size must be &lt;b&gt;5 MB or less&lt;/b&gt;;&lt;br&gt;image dimensions must be &lt;b&gt;2048 x 2048 px or smaller&lt;/b&gt;. The &lt;b&gt;Cartoonify&lt;/b&gt; button stays disabled until a valid file is chosen." vertex="1">
          <mxGeometry height="105" width="657" x="158" y="250" as="geometry" />
        </mxCell>
        <mxCell id="a23" edge="1" parent="1" source="s2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=4;" value="" vertex="1">
          <mxGeometry height="135" width="750" x="75" y="392" as="geometry" />
        </mxCell>
        <mxCell id="s3n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="③" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="408" as="geometry" />
        </mxCell>
        <mxCell id="s3t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Request a Blob SAS Upload URL&lt;/b&gt;&lt;br&gt;&lt;b&gt;POST /api/upload-url&lt;/b&gt; with &lt;tt&gt;Authorization: Bearer &amp;lt;JWT&amp;gt;&lt;/tt&gt; and &lt;tt&gt;{ content_type }&lt;/tt&gt;. The &lt;b&gt;upload_url function&lt;/b&gt; validates the JWT&lt;br&gt;signature in-code against the &lt;b&gt;Entra JWKS endpoint&lt;/b&gt; — unauthenticated requests are rejected before any handler runs.&lt;br&gt;The function generates a time-sortable &lt;b&gt;job_id&lt;/b&gt; and calls &lt;tt&gt;generate_blob_sas&lt;/tt&gt;,&lt;br&gt;returning a write-only &lt;b&gt;SAS URL&lt;/b&gt; valid for &lt;b&gt;5 minutes&lt;/b&gt;. The browser enforces a 0–5 MB size constraint client-side." vertex="1">
          <mxGeometry height="120" width="657" x="158" y="400" as="geometry" />
        </mxCell>
        <mxCell id="a34" edge="1" parent="1" source="s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=4;" value="" vertex="1">
          <mxGeometry height="115" width="750" x="75" y="557" as="geometry" />
        </mxCell>
        <mxCell id="s4n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#82b366;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="④" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="572" as="geometry" />
        </mxCell>
        <mxCell id="s4t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Upload Image Directly to Blob Storage&lt;/b&gt;&lt;br&gt;The browser PUTs the image file &lt;b&gt;directly to Blob Storage&lt;/b&gt; using the SAS URL — bypassing Azure Functions entirely.&lt;br&gt;Image data never touches the function network path. CORS is configured on the storage account to permit&lt;br&gt;the PUT from the web origin. Blob Storage stores the file at &lt;b&gt;originals/&amp;lt;owner&amp;gt;/&amp;lt;job_id&amp;gt;.&amp;lt;ext&amp;gt;&lt;/b&gt; in the private media container." vertex="1">
          <mxGeometry height="100" width="657" x="158" y="565" as="geometry" />
        </mxCell>
        <mxCell id="a45" edge="1" parent="1" source="s4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=4;" value="" vertex="1">
          <mxGeometry height="155" width="750" x="75" y="702" as="geometry" />
        </mxCell>
        <mxCell id="s5n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑤" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="718" as="geometry" />
        </mxCell>
        <mxCell id="s5t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Select Style &amp;amp; Submit the Cartoon Job&lt;/b&gt;&lt;br&gt;Pick a style: &lt;b&gt;Pixar 3D · Simpsons · Anime · Comic Book · Watercolor · Pencil Sketch&lt;/b&gt;.&lt;br&gt;Optionally type extra instructions (500 chars max). Click &lt;b&gt;Cartoonify&lt;/b&gt;.&lt;br&gt;&lt;b&gt;POST /api/generate&lt;/b&gt; sends &lt;tt&gt;{ job_id, key, style, prompt_extra }&lt;/tt&gt;. The &lt;b&gt;submit function&lt;/b&gt; validates&lt;br&gt;the style, checks Blob Storage to confirm the upload exists, queries Cosmos DB to enforce the&lt;br&gt;&lt;b&gt;daily quota&lt;/b&gt; (max 10 cartoons per UTC day), writes &lt;tt&gt;status=submitted&lt;/tt&gt;, then enqueues on &lt;b&gt;Service Bus&lt;/b&gt;. Returns &lt;b&gt;202 Accepted&lt;/b&gt;." vertex="1">
          <mxGeometry height="140" width="657" x="158" y="710" as="geometry" />
        </mxCell>
        <mxCell id="a56" edge="1" parent="1" source="s5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=4;" value="" vertex="1">
          <mxGeometry height="140" width="750" x="75" y="887" as="geometry" />
        </mxCell>
        <mxCell id="s6n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#d79b00;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑥" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="903" as="geometry" />
        </mxCell>
        <mxCell id="s6t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Service Bus Triggers the Worker Function&lt;/b&gt;&lt;br&gt;Service Bus delivers the job message to the &lt;b&gt;cartoonify_worker function&lt;/b&gt; (Python 3.11 + Pillow)&lt;br&gt;running in the &lt;b&gt;Azure Functions FC1 Flex Consumption&lt;/b&gt; plan with &lt;b&gt;2048 MB&lt;/b&gt; instance memory. The Service Bus&lt;br&gt;lock duration is &lt;b&gt;3 minutes&lt;/b&gt;, ensuring the message stays hidden while the worker runs. Batch size is &lt;b&gt;1&lt;/b&gt; — one OpenAI call per message.&lt;br&gt;The worker marks &lt;tt&gt;status=processing&lt;/tt&gt; in Cosmos DB, downloads the original from Blob Storage, then runs &lt;b&gt;Pillow&lt;/b&gt;:&lt;br&gt;EXIF strip → RGB convert → center-square crop → resize to &lt;b&gt;1024 x 1024 px&lt;/b&gt; → encode as PNG for OpenAI." vertex="1">
          <mxGeometry height="125" width="657" x="158" y="895" as="geometry" />
        </mxCell>
        <mxCell id="a67" edge="1" parent="1" source="s6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=4;" value="" vertex="1">
          <mxGeometry height="150" width="750" x="75" y="1057" as="geometry" />
        </mxCell>
        <mxCell id="s7n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#9673a6;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑦" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1073" as="geometry" />
        </mxCell>
        <mxCell id="s7t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;OpenAI Generates the Cartoon&lt;/b&gt;&lt;br&gt;The worker calls &lt;b&gt;openai.images.edit&lt;/b&gt; using model &lt;tt&gt;gpt-image-1&lt;/tt&gt; via the &lt;b&gt;OpenAI API&lt;/b&gt; (&lt;tt&gt;api.openai.com&lt;/tt&gt;),&lt;br&gt;authenticated with an &lt;b&gt;OPENAI_API_KEY&lt;/b&gt; stored as a Function App setting.&lt;br&gt;The request includes the &lt;b&gt;normalized PNG image&lt;/b&gt; and a &lt;b&gt;style prompt&lt;/b&gt; — e.g. &lt;i&gt;Pixar 3D animated portrait,&lt;br&gt;subsurface skin shading, warm rim lighting, large expressive eyes&lt;/i&gt; — plus any extra user instructions.&lt;br&gt;The API timeout is &lt;b&gt;120 seconds&lt;/b&gt;. If &lt;tt&gt;OPENAI_API_KEY&lt;/tt&gt; is not set the worker marks the job &lt;tt&gt;error&lt;/tt&gt; immediately.&lt;br&gt;The model returns the generated cartoon as a &lt;b&gt;base64-encoded PNG&lt;/b&gt;." vertex="1">
          <mxGeometry height="135" width="657" x="158" y="1065" as="geometry" />
        </mxCell>
        <mxCell id="a78" edge="1" parent="1" source="s7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=4;" value="" vertex="1">
          <mxGeometry height="120" width="750" x="75" y="1237" as="geometry" />
        </mxCell>
        <mxCell id="s8n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#82b366;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑧" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1253" as="geometry" />
        </mxCell>
        <mxCell id="s8t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Store Cartoon &amp;amp; Update Job Status&lt;/b&gt;&lt;br&gt;The worker uploads the generated cartoon PNG to Blob Storage at &lt;b&gt;cartoons/&amp;lt;owner&amp;gt;/&amp;lt;job_id&amp;gt;.png&lt;/b&gt; in the media container,&lt;br&gt;then updates the Cosmos DB job document: &lt;tt&gt;status=complete&lt;/tt&gt;, &lt;tt&gt;cartoon_key&lt;/tt&gt;, and &lt;tt&gt;completed_at&lt;/tt&gt;.&lt;br&gt;Both blobs are subject to a &lt;b&gt;7-day Blob Storage lifecycle policy&lt;/b&gt; and matching &lt;b&gt;Cosmos DB per-item TTL&lt;/b&gt;.&lt;br&gt;On any exception the worker marks &lt;tt&gt;status=error&lt;/tt&gt; and does not re-raise — Service Bus does not redrive." vertex="1">
          <mxGeometry height="105" width="657" x="158" y="1245" as="geometry" />
        </mxCell>
        <mxCell id="a89" edge="1" parent="1" source="s8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="125" width="750" x="75" y="1387" as="geometry" />
        </mxCell>
        <mxCell id="s9n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑨" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1403" as="geometry" />
        </mxCell>
        <mxCell id="s9t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Poll for Result &amp;amp; Display Cartoon&lt;/b&gt;&lt;br&gt;While the job runs, the browser calls &lt;b&gt;GET /api/result/{job_id}&lt;/b&gt; every &lt;b&gt;2 seconds&lt;/b&gt; (up to 90 attempts, ~3 minutes).&lt;br&gt;Each response includes the current &lt;tt&gt;status&lt;/tt&gt; field. When &lt;tt&gt;status=complete&lt;/tt&gt;, the API returns&lt;br&gt;&lt;b&gt;SAS download URLs&lt;/b&gt; (4-hour expiry) for both the original upload and the generated cartoon.&lt;br&gt;The cartoon renders in the current-job panel. The history gallery reloads and auto-refreshes every 10 s while any tile is pending." vertex="1">
          <mxGeometry height="110" width="657" x="158" y="1395" as="geometry" />
        </mxCell>
        <mxCell id="a910" edge="1" parent="1" source="s9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="120" width="750" x="75" y="1542" as="geometry" />
        </mxCell>
        <mxCell id="s10n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑩" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1558" as="geometry" />
        </mxCell>
        <mxCell id="s10t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Browse History, Download &amp;amp; Delete&lt;/b&gt;&lt;br&gt;&lt;b&gt;GET /api/history&lt;/b&gt; returns the last &lt;b&gt;50 cartoons&lt;/b&gt; for the authenticated user, newest first,&lt;br&gt;each with SAS download URLs valid for 4 hours. The gallery renders as a responsive tile grid&lt;br&gt;showing both the original photo and generated cartoon side by side.&lt;br&gt;Click &lt;b&gt;Download&lt;/b&gt; to save the PNG. Click &lt;b&gt;Delete&lt;/b&gt; to call &lt;b&gt;DELETE /api/history/{job_id}&lt;/b&gt; — which removes&lt;br&gt;the original, the cartoon, and the Cosmos DB document. Items expire automatically after &lt;b&gt;7 days&lt;/b&gt;." vertex="1">
          <mxGeometry height="105" width="657" x="158" y="1550" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
